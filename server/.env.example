DATABASE_URL="file:./prisma/dev.db"
PORT=8787
JWT_SECRET="change_me_in_real_env"
JWT_EXPIRES_IN="7d"

# публичная база для ссылок на uploads (в проде поставить домен)
# пример: https://94club.ru  или  https://94club.online
PUBLIC_BASE_URL="http://localhost:8787"

# bootstrap admin (создастся автоматически при старте, если нет)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="admin12345"
ADMIN_ROLE="admin"

# CORS
# dev: http://localhost:5173
# prod: https://94club.ru,https://94club.online
CORS_ORIGINS="http://localhost:5173"

# если хочешь, чтобы Node сам раздавал собранный фронт из ../dist
SERVE_FRONTEND="false"

# уведомления о заявках с главной (join): опционально
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""


