generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
}

enum EventStatus {
  СКОРО
  ПРОШЛО
  ЧЕРНОВИК
}

model User {
  id           Int      @id @default(autoincrement())
  login        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(admin)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Event {
  id          Int         @id @default(autoincrement())
  title       String
  category    String
  date        String
  location    String
  description String
  image       String
  status      EventStatus @default(СКОРО)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([title])
  @@index([category])
  @@map("events")
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String
  tag       String
  image     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([title])
  @@index([tag])
  @@map("gallery")
}

model RaffleEntry {
  id           Int      @id @default(autoincrement())
  name         String
  vk           String?  @unique
  telegram     String?  @unique
  ticketNumber String   @unique @map("ticket_number")
  createdAt    DateTime @default(now()) @map("created_at")

  winner       RaffleWinner?

  @@index([createdAt])
  @@map("raffle_entries")
}

model RaffleWinner {
  id        Int        @id @default(autoincrement())
  entryId   Int        @unique @map("entry_id")
  place     Int        @unique
  createdAt DateTime   @default(now()) @map("created_at")

  entry     RaffleEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("raffle_winners")
}

