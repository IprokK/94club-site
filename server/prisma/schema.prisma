generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
}

enum EventStatus {
  СКОРО
  ПРОШЛО
  ЧЕРНОВИК
}

model User {
  id           Int      @id @default(autoincrement())
  login        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(admin)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Event {
  id          Int         @id @default(autoincrement())
  title       String
  category    String
  date        String
  location    String
  description String
  image       String
  status      EventStatus @default(СКОРО)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([title])
  @@index([category])
  @@map("events")
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String
  tag       String
  image     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([title])
  @@index([tag])
  @@map("gallery")
}

model RaffleEntry {
  id        Int     @id @default(autoincrement())
  name      String
  nameKey   String  @unique @map("name_key")
  vk        String
  vkKey     String  @unique @map("vk_key")
  telegram  String
  tgKey     String  @unique @map("tg_key")
  ticketNumber String @unique @map("ticket_number")
  createdAt DateTime @default(now()) @map("created_at")

  conditionVkOk Boolean @default(false) @map("condition_vk_ok")
  conditionTgOk Boolean @default(false) @map("condition_tg_ok")
  verifiedNote  String? @map("verified_note")

  winner RaffleWinner?

  @@index([createdAt])
  @@map("raffle_entries")
}

model RaffleWinner {
  id        Int        @id @default(autoincrement())
  entryId   Int        @unique @map("entry_id")
  place     Int        @unique
  createdAt DateTime   @default(now()) @map("created_at")

  entry     RaffleEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("raffle_winners")
}

model SiteSettings {
  id            Int      @id @default(1)
  calendarLabel String   @default("календарь") @map("calendar_label")
  calendarPath  String   @default("/events") @map("calendar_path")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model JoinRequest {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("join_requests")
}

